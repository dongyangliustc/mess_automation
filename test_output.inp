!***************************************************
!               GLOBAL SECTION
!***************************************************
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!
!
TemperatureList[K]                      300.0 400.0 500.0 600.0 700.0 800.0 900.0 1000.0
PressureList[atm]                       1.0!
!
EnergyStepOverTemperature               0.2         ! [Discretization energy step (global relax matrix)] / T                   
ExcessEnergyOverTemperature             50         ! [Highest barrier in the model (global relax matrix)] / T                      
ModelEnergyLimit[kcal/mol]              400        ! Highest reference energy used in the calculation ( or ReferenceEnergy[kcal/mol])
!
CalculationMethod                       direct     ! direct or low-eigenvalue                     
!
WellCutoff                              20         ! well truncation parameter : Max { dissociation limit (min barrier rel. to bottom of the well) / T }
ChemicalEigenvalueMax                   0.2        ! Max chemical eigenvalue / Lowest Collision relaxation eigenvalue 
!
ReductionMethod                         diagonalization ! [low eigenvalue method only] diagonalization or projection (default)
!      
!!!!!!!!!!test!!!!!!!!!!!!!!!!!!!!
!EnergyStepOverTemperature             0.3          #Ratio of discretization energy step to T 
!ExcessEnergyOverTemperature           40
!WellCutoff                            10
!ChemicalEigenvalueMin                 1.e-6          #only for direct diagonalization method
!!!!!!!!!test!!!!!!!!!!!!!!!!!!!!!!!!!!
RateOutput                               mess.out                        ! DLPNO-QZ//M052x-D3/6-311++G(d,p),TST 
!LogOutput                               mess.log                             ! log file name
!EigenvalueOutput                        mess_eigval.out                      ! eigenvalue output file name
!EigenvectorOutput                       mess_eigvect.out                     ! eigenvector output file name          
!PEDOutput                               mess_ped.out                         ! Product energy distributions file name             
!
!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!***************************************************
!               MODEL SECTION
!***************************************************
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!
!                          
Model        
!                                                           
  EnergyRelaxation                                                      ! Default collisional energy relaxation kernel                              
    Exponential                                                         ! Currently the only possible energy relaxation model              
       Factor[1/cm]                     350.0                            ! (Delta_E_down)^(0) @ standard T (300 K)                          
       Power                            0.85                           ! Power n in the expression (Delta_E_down) = (Delta_E_down)^(0) (T/T0)^(n)
       ExponentCutoff                   10                              ! if (Delta_E) / (Delta_E_down) > value  transition probability is zero      
    End  
!                                                               
  CollisionFrequency                                                    ! Collision frequency model
    LennardJones                                                        ! Currently the only possible collisional frequency model  based on LJ potential
       Epsilons[K]                       10.0   595.38                 ! Epsilon_1 and Epsilon_2 He and 4-Hydroxystyrene         
       Sigmas[angstrom]                  2.55    4.89                   ! Sigma_1 and Sigma_2 
       Masses[amu]                       4.0   78.05               ! Masses of the buffer gas molecule and of the complex (check order)
    End      
!
!*************************************************
!
!***************************************************
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!***************************************************
!  REACTANTS
!***************************************************
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
